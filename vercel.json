{
  "version": 2,
  "buildCommand": "cd synthese && npm install && NODE_OPTIONS=--no-deprecation npm run build",
  "outputDirectory": "synthese/build",
  "env": {
    "CI": "false",
    "NODE_VERSION": "18"
  },
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://backend-synthese.onrender.com/api/:path*"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
