{
  "version": 2,
  "env": {
    "CI": "false"
  },
  "builds": [
    {
      "src": "backend/server.js",
      "use": "@vercel/node"
    },
    {
      "src": "synthese/package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "build"
      }
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "backend/server.js"
    },
    {
      "src": "/(.*)",
      "dest": "/synthese/$1",
      "check": true
    },
    {
      "src": "/(.*)",
      "dest": "/synthese/index.html"
    }
  ]
}
